<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <View
        android:id="@+id/blur_top_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#4DFFFFFF" 
        app:layout_constraintTop_toTopOf="parent" />


    <include
        layout="@layout/app_bar_main"
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/appbar"
        android:layout_above="@id/blur_bottom_container" />

    <com.omarea.common.ui.BlurBottomBarLayout
        
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/krscript_item_ripple_in"
        android:layout_alignParentBottom="true" >

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:tabBackground="@android:color/transparent"
            app:tabRippleColor="@android:color/transparent"
            app:tabGravity="fill"
            app:tabMode="fixed"
            app:tabIndicatorHeight="0dp"
            app:tabMaxWidth="0dp"
            app:tabIndicatorFullWidth="false" />
            
                <View
        android:id="@+id/blur_bottom_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#4DFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent" />
    </com.omarea.common.ui.BlurBottomBarLayout>
</RelativeLayout>
