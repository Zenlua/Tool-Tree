<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/dialogRoot"
    android:animateLayoutChanges="true"
    android:clickable="true"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageButton
        android:id="@+id/btn_hide"
        android:scaleX="0.8"
        android:scaleY="0.8"
        style="@style/SceneButton"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="8dp"
        android:scaleType="centerInside"
        android:padding="7dp"
        android:src="@drawable/kr_hide"
        android:contentDescription="@null" />

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@id/btn_hide"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            style="@style/dialogTitle" />

        <TextView
            android:id="@+id/desc"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            android:layout_marginTop="4dp"
            style="@style/dialogDesc" />

    </LinearLayout>

    <!-- Thay đổi: Đồng bộ lại layout_below để tránh đè lên ProgressBar nếu cần -->
    <ScrollView
        android:id="@+id/log_scroll_view"
        android:layout_marginTop="16dp"
        android:background="@drawable/krscript_item_ripple_kon"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:clipToOutline="true"
        android:layout_above="@id/input_row"
        android:layout_below="@+id/top_bar">

        <TextView
            android:id="@+id/shell_output"
            android:breakStrategy="simple"
            android:textIsSelectable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:padding="12dp" />

    </ScrollView>

    <!-- Ô nhập liệu hiển thị khi shell script yêu cầu người dùng nhập dữ liệu (đọc bằng lệnh read) -->
    <LinearLayout
        android:id="@+id/input_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottom_actions"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <EditText
            android:id="@+id/shell_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_shell_input"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true"
            android:fontFamily="monospace"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_send_input"
            style="@style/dialogConfirmBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/btn_send_input" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_copy"
            style="@style/dialogCancelBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_copy_output" />

        <Button
            android:id="@+id/btn_cancel"
            style="@style/dialogWarningBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_cancel" />

        <Button
            android:id="@+id/btn_exit"
            style="@style/dialogConfirmBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_exit" />

    </LinearLayout>

    <!-- SỬA TẠI ĐÂY: Thay đổi toàn bộ px sang dp để đồng bộ cơ chế hiển thị -->
    <ProgressBar
        android:id="@+id/action_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_below="@id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_marginTop="13dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:indeterminate="true"
        android:progress="0"
        android:max="100" />

</RelativeLayout>