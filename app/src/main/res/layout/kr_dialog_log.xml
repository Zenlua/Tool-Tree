<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/dialogRoot"
    android:animateLayoutChanges="true"
    android:clickable="true"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title"
                style="@style/dialogTitle"
                android:paddingStart="0dp"
                android:paddingTop="0dp"
                android:paddingEnd="0dp" />

            <TextView
                android:id="@+id/desc"
                style="@style/dialogDesc"
                android:layout_marginTop="4dp"
                android:paddingStart="0dp"
                android:paddingTop="0dp"
                android:paddingEnd="0dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/top_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_wrap"
                style="@style/SceneButton"
                android:contentDescription="@null"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:scaleX="0.8"
                android:scaleY="0.8"
                android:src="@drawable/ic_wrap_text" />

            <ImageButton
                android:id="@+id/btn_hide"
                style="@style/SceneButton"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:scaleX="0.8"
                android:scaleY="0.8"
                android:src="@drawable/kr_hide" />

        </LinearLayout>

    </LinearLayout>

    <!-- 1. Thêm android:fillViewport="true" vào ScrollView -->
    <ScrollView
        android:id="@+id/log_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/input_row"
        android:layout_below="@+id/header_row"
        android:layout_marginTop="16dp"
        android:background="@drawable/krscript_item_ripple_kon"
        android:clipToOutline="true"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbarSize="1dp">

        <!-- 2. Đổi layout_height của TextView thành match_parent -->
        <TextView
            android:id="@+id/shell_output"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:breakStrategy="simple"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:textIsSelectable="true"
            android:textSize="12sp" />

    </ScrollView>

    <LinearLayout
        android:id="@+id/input_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottom_actions"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <EditText
            android:id="@+id/shell_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:fontFamily="monospace"
            android:hint="@string/hint_shell_input"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true"
            android:textSize="14sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_copy"
            style="@style/dialogCancelBtn"
            android:layout_weight="1"
            android:text="@string/btn_copy_output" />

        <Button
            android:id="@+id/btn_cancel"
            style="@style/dialogWarningBtn"
            android:layout_weight="1"
            android:text="@string/btn_cancel" />

        <Button
            android:id="@+id/btn_exit"
            style="@style/dialogConfirmBtn"
            android:layout_weight="1"
            android:text="@string/btn_exit" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/action_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_below="@id/header_row"
        android:layout_marginStart="10dp"
        android:layout_marginTop="13dp"
        android:layout_marginEnd="10dp"
        android:indeterminate="true"
        android:max="100"
        android:progress="0" />

</RelativeLayout>
