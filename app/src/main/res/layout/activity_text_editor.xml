<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <ScrollView
        android:id="@+id/main_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/editor_special_chars_scroll"
        android:layout_marginTop="?android:actionBarSize"
        android:clickable="true"
        android:fadingEdge="vertical"
        android:fillViewport="true"
        android:focusable="true"
        android:scrollbars="none">

        <!-- Đổi layout_height thành match_parent để View divider kéo dài hết màn hình -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/editor_line_numbers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top|end"
                android:includeFontPadding="false"
                android:minWidth="32dp"
                android:paddingStart="12dp"
                android:paddingTop="16dp"
                android:paddingEnd="8dp"
                android:paddingBottom="16dp"
                android:text="1"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp"
                android:typeface="monospace" />

            <!-- Dải ngăn cách phân chia số dòng và khung code -->
            <View
                android:id="@+id/editor_line_divider"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:alpha="0.2"
                android:background="?android:attr/textColorSecondary" />

            <!-- Thêm HorizontalScrollView hỗ trợ tính năng Tắt Wrap Text (Cuộn ngang) -->
            <HorizontalScrollView
                android:id="@+id/editor_horizontal_scroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="none">

                <FrameLayout
                    android:id="@+id/editor_content_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true">

                    <EditText
                        android:id="@+id/editor_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="top|start"
                        android:hint="@string/editor_hint_empty"
                        android:imeOptions="flagNoExtractUi"
                        android:includeFontPadding="false"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:minHeight="300dp"
                        android:paddingStart="8dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textColorHint="?android:attr/textColorSecondary"
                        android:textSize="14sp"
                        android:typeface="monospace" />

                </FrameLayout>

            </HorizontalScrollView>

        </LinearLayout>

    </ScrollView>

    <!-- Hàng ký tự đặc biệt: luôn nằm cố định ở đáy màn hình -->
    <HorizontalScrollView
        android:id="@+id/editor_special_chars_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="?android:attr/colorBackground"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/editor_special_chars_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

    </HorizontalScrollView>

    <include
        layout="@layout/app_bar_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</RelativeLayout>
