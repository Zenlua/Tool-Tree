<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <ScrollView
        android:id="@+id/main_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?android:actionBarSize"
        android:layout_above="@id/editor_special_chars_scroll"
        android:fadingEdge="vertical"
        android:fillViewport="true"
        android:scrollbars="none">

        <!-- Hàng ngang gồm: cột số dòng (editor_line_numbers) + vùng chứa nội dung soạn thảo.
             Container này LUÔN LÀ con duy nhất của ScrollView; applyWrapState() trong code chỉ
             hoán đổi nội dung BÊN TRONG editor_content_container (giữa EditText trực tiếp khi
             wrap, và HorizontalScrollView bọc EditText khi không wrap), để cột số dòng không
             bao giờ bị tách rời khỏi EditText. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/editor_line_numbers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top|end"
                android:minWidth="28dp"
                android:paddingStart="12dp"
                android:paddingTop="16dp"
                android:paddingEnd="8dp"
                android:paddingBottom="16dp"
                android:text="1"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp"
                android:typeface="monospace" />

            <FrameLayout
                android:id="@+id/editor_content_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <EditText
                    android:id="@+id/editor_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="top|start"
                    android:hint="@string/editor_hint_empty"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:imeOptions="flagNoExtractUi"
                    android:paddingStart="0dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textColorHint="?android:attr/textColorSecondary"
                    android:textSize="14sp"
                    android:typeface="monospace" />

            </FrameLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Hàng ký tự đặc biệt: luôn nằm cố định ở đáy màn hình, tự động được đẩy lên ngay phía
         trên bàn phím khi bàn phím hiện ra (xử lý trong setupKeyboardInsets()). Danh sách nút
         ký tự được tạo động trong Kotlin (setupSpecialCharsBar()) và thêm vào container này. -->
    <HorizontalScrollView
        android:id="@+id/editor_special_chars_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="?android:attr/colorBackground"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/editor_special_chars_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

    </HorizontalScrollView>

    <include
        layout="@layout/app_bar_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</RelativeLayout>