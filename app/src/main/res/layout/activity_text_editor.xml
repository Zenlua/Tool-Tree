<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <ScrollView
        android:id="@+id/main_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?android:actionBarSize"
        android:layout_above="@id/editor_special_chars_scroll"
        android:descendantFocusability="afterDescendants"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:fadingEdge="vertical"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/editor_line_numbers"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="top|end"
                android:minWidth="28dp"
                android:paddingStart="12dp"
                android:paddingTop="16dp"
                android:paddingEnd="8dp"
                android:paddingBottom="16dp"
                android:text="1"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp"
                android:typeface="monospace" />

            <View
                android:id="@+id/editor_divider"
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_vertical"
                android:background="?android:attr/textColorTertiary"/>

            <LinearLayout
                android:id="@+id/editor_content_container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="bottom"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/editor_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="top|start"
                    android:hint="@string/editor_hint_empty"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:imeOptions="flagNoExtractUi"
                    android:paddingStart="0dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textColorHint="?android:attr/textColorSecondary"
                    android:textSize="14sp"
                    android:typeface="monospace" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <HorizontalScrollView
        android:id="@+id/editor_special_chars_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="?android:attr/colorBackground"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/editor_special_chars_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

    </HorizontalScrollView>

    <include
        layout="@layout/app_bar_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</RelativeLayout>