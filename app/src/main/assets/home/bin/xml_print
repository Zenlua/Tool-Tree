#!/data/data/com.tool.tree/files/home/bin/bash

if [ "$1" == '-h' ] || [ "$1" == '--help' ] || [ -z "$1" ]; then
echo -e "Use: xml_print file.xml\n  or: xml_print 'text content'"
exit
fi

if [ -f "$1" ]; then
    sed -u -z -e 's|\&|\&amp;|g' -e 's|§|\&#xA;|g' < "$1"
else
    echo "$@" | sed -u -z -e 's|\&|\&amp;|g' -e 's|§|\&#xA;|g'
fi
