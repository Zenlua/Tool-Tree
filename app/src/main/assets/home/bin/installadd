#!/data/data/com.tool.tree/files/home/bin/bash
# Kakathic

source language

if [ "$1" == '-h' ] || [ "$1" == '--help' ] || [ -z "$1" ]; then
echo "installadd [file.add|http://file.add] folder_ouput"
exit
fi

echo "${more_text_4} $1"
echo

if [ -f "$1" ]; then
loadmd="$(7z x "$1" addon.prop -so 2>/dev/null)"
    if [ -z "$loadmd" ]; then
    echo "Add-on incompatibility error !" >&2
    exit 1
    fi
else
file_random="addon_$RANDOM.add"
taive "$1" "$TMP/$file_random" 2>&1
loadmd="$(7z x "$TMP/$file_random" addon.prop -so 2>/dev/null)"
    if [ -z "$loadmd" ]; then
    echo "Download add-on error !" >&2
    exit 1
    fi
fi

gprop(){ echo "$loadmd" | awk -F= -v k="$1" '$1==k{print $2; exit}'; }
loadid="$(gprop id)"

if [ -z "$loadid" ]; then
echo "ID not found in addon.prop" >&2
exit 1
fi

echo "$name_text: $(gprop name) $(gprop version)"
echo

echo "ID: $loadid"
echo

echo "$author_text: $(gprop author)"
echo

[ -d "$2/$loadid" ] && find "$2/$loadid" -maxdepth 1 ! -path "$2/$loadid" ! -name 'download.prop' -exec rm -rf {} +
mkdir -p "$2/$loadid"

echo "$addon_text_3"
echo

if [ -f "$1" ]; then
    7z x "$1" -o"$2/$loadid" -y &>$TMP/unpack_add-on.log
    slog "check_sum_addon_$loadid" "$(checksum $1)"
else
    7z x "$TMP/$file_random" -o"$2/$loadid" -y &>$TMP/unpack_add-on.log
    slog "check_sum_addon_$loadid" "$(checksum $TMP/$file_random)"
    rm -f $TMP/$file_random
fi

echo 0 > "$2/$loadid/status"
chmod -R 755 "$2/$loadid"

if [ -f "$2/$loadid/install.sh" ]; then
    "$2/$loadid/install.sh"
    rm -fr "$2/$loadid/install.sh"
fi

echo "$flash_text_12"
