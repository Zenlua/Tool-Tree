#!/data/data/com.tool.tree/files/home/bin/bash

show_help(){
echo "Use: answeractivity -a|--am -m|--max 5 -a|--answer '1:A|2:B|3:C|4:D' -t|--time 20"
echo
echo "-a|--am: forced use of am"
echo "-m|--max: Limit the number ex: 0 to 5"
echo "-a|--answer: answer button, ex: 1:A|2:B|3:C|4:D"
echo "-t|--time: waiting timeout, ex: default 20s"
exit 0
}

MAXNUMs=""; ANSWERs=""; AMON=""; TIMEOUTs="";
while [ $# -gt 0 ]; do
  case "$1" in
    -m|--max)
      MAXNUMs="$2"
      shift 2
      ;;
    -a|--answer)
      ANSWERs="$2"
      shift 2
      ;;
    -t|--time)
      TIMEOUTs="$2"
      shift 2
      ;;
    -a|--am)
      AMON=1
      shift
      ;;
    -h|--help)
      show_help
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

# Mặc định
CMDs="start -n com.tool.tree/com.tool.tree.AnswerActivity "
[ "$MAXNUMs" ] && CMDs+="--es max $MAXNUMs "
[ "$TIMEOUTs" ] && CMDs+="--es time $TIMEOUTs "
[ "$ANSWERs" ] && CMDs+="--es answer \"$ANSWERs\" "
if [ "$AMON" == 1 ] || [ -z "$shell_progres" ];then
    eval "am $CMDs" &>/dev/null
else
    echo "am:[$CMDs]"
fi

text_answer="$TEMP/answer.log"
sleep 0.2

while [ ! -f "$text_answer" ]; do
    sleep 0.2
done

[ -f "$text_answer" ] && cat "$text_answer"
