#!/data/data/com.tool.tree/files/home/bin/bash

show_help(){
echo "Use: answeractivity -a|--am -m|--max 5 -a|--answer '1:A|2:B|3:C|4:D' "
exit 0
}

MAXNUMs=""; ANSWERs=""; AMON="";
while [ $# -gt 0 ]; do
  case "$1" in
    -m|--max)
      MAXNUMs="$2"
      shift 2
      ;;
    -a|--answer)
      ANSWERs="$2"
      shift 2
      ;;
    -a|--am)
      AMON=1
      shift
      ;;
    -h|--help)
      show_help
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

# Mặc định
CMDs="start -n com.tool.tree/com.tool.tree.AnswerActivity "
[ "$MAXNUMs" ] && CMDs+="--max $MAXNUMs "
[ "$ANSWERs" ] && CMDs+="--es answer \"$ANSWERs\" "
if [ "$AMON" == 1 ] || [ -z "$shell_progres" ];then
    eval "am $CMDs" &>/dev/null
else
    echo "am:[$CMDs]"
fi

while [ ! -f "$TEMP/answer.log" ]; do
    sleep 1
done

cat $TEMP/answer.log
