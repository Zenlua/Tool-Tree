# Kakathic

# ngôn ngữ English
source $ETC/lang/default.bash

# Chạy file ngôn ngữ có sẵn
if [ -f "$ETC/lang/${LANGUAGE}-${COUNTRY}.bash" ]; then
source "$ETC/lang/${LANGUAGE}-${COUNTRY}.bash"
elif [ -f "$ETC/lang/$LANGUAGE.bash" ]; then
source "$ETC/lang/$LANGUAGE.bash"
fi

# chạy google dịch
[ -f $ETC/lang/auto.sh ] && source $ETC/lang/auto.sh
