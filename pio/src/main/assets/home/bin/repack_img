#!/data/data/com.tool.tree/files/home/bin/bash
shopt -s extglob
set -o pipefail
#set -x
source language 2>/dev/null
#threads=$(nproc)
show_help() {
  echo "Usage: repack_img -i <input> -o <output> <flags>"
  echo
  echo "  -i    input file"
  echo "  -o    output folder"
  echo "  -n    compressed erofs: lz4hc"
  echo "          lz4hc: 0-12"
  echo "          lz4: 0"
  echo "          lzma: 0-9"
  echo "          deflate: 0-9"
  echo "          zstd: 0-22"
  echo "  -l    default: 8, 0-22"
  echo "  -c    list convert: raw, dat, br, zstd, sparse, default: raw"
  echo "  -s    default: 0, free size calculated by mb for example 100mb free only works in ext4, f2fs"
  echo "  -k    build default: 0"
  echo "          0: auto detect partition"
  echo "          1: ro-erofs, (mkfs.erofs)"
  echo "          2: rw-ext4, (make_ext4fs)"
  echo "          3: rw-ext4, (e2fsdroid)"
  echo "          4: ro-f2fs, (make_f2fs)"
  echo "          5: rw-f2fs, (make_f2fs)"
  echo "          6: ro-erofs, (imgkit_scuti)"
  echo "          7: rw-ext4, (imgkit_scuti)"
  echo "          8: ro-erofs, (mkfs.erofs.old)"
  echo "  -d    delete folder after build: 1"
  echo "          0: false"
  echo "          1: true"
  echo "  -p    Patching with fs_config and fs_contexts: 1"
  echo "          0: false"
  echo "          1: true"
  echo "  -h    show help"
  exit 1
}

if [[ $# -eq 0 || "$1" != -* ]]; then
show_help
fi

OUTPUT=''; NENEROFS=''; CONVER=''; LVLNEN=''; 
SAINEN=''; TTBUILDI=''; CDELIMG=''; show_help=''; DISATFS='';
while getopts ":i:o:n:l:c:s:k:d:p:h" opt; do
  case $opt in
    i) INPUT="$OPTARG" ;;
    o) OUTPUT="$OPTARG" ;;
    n) NENEROFS="$OPTARG" ;;
    c) CONVER="$OPTARG" ;;
    l) LVLNEN="$OPTARG" ;;
    s) SAINEN="$OPTARG" ;;
    k) TTBUILDI="$OPTARG" ;;
    d) CDELIMG="$OPTARG" ;;
    p) DISATFS="$OPTARG" ;;
    h) show_help ;;
    \?) echo "! Not understand -$OPTARG"; show_help ;;
    :) echo "! Lack of value for -$OPTARG"; show_help ;;
  esac
done

if [[ -z "$INPUT" || -z "$OUTPUT" ]]; then
echo "Lack of value:
-i $INPUT
-o $OUTPUT" >&2
exit 1
fi

[[ -z "$NENEROFS" ]] && NENEROFS='lz4hc'
[[ -z "$LVLNEN" ]] && LVLNEN=4
[[ -z "$SAINEN" ]] && SAINEN=0
[[ -z "$TTBUILDI" ]] && TTBUILDI=0
[[ -z "$CDELIMG" ]] && CDELIMG=1
[[ -z "$CONVER" ]] && CONVER='raw'
[[ -z "$DISATFS" ]] && DISATFS=1

[ -f $ETC/mke2fs.conf ] && export MKE2FS_CONFIG="$ETC/mke2fs.conf"
# Thời gian build
time_build="$(glog build_times)"
[ -z "$time_build" ] && time_build="1230768000"
info="${INPUT%/*}/config/${INPUT##*/}_info"
fs_config="${INPUT%/*}/config/${INPUT##*/}_fs_config"
file_contexts="${INPUT%/*}/config/${INPUT##*/}_file_contexts"
fs_options="${INPUT%/*}/config/${INPUT##*/}_fs_options"
saved="$OUTPUT/out/${INPUT##*/}.img"
info_size="${INPUT%/*}/config/${INPUT##*/}_size.txt"
kernel_dts_md5="${INPUT%/*}/config/${INPUT##*/}_kernel_dts_md5.txt"
dts_md5="${INPUT%/*}/config/${INPUT##*/}_dts_md5.txt"
lvnen="$(glog nen_br 8)"
info_type="$(cat "$info" 2>/dev/null)"

# Ép build mặc định đối với định dạng sau
if [[ "$info_type" =~ ^(vendor_boot|logo|squashfs|boot|vbmeta|vbmeta_system|dtbo)$ ]];then
TTBUILDI=0
CONVER='raw'
fi

[ -f "$saved" ] && rm -fr "$saved"

if [ "$CONVER" != "raw" ];then
out_saved="$saved"
saved="$TMP/${saved##*/}"
fi

# Chọn định dạng tệp phân vùng
if [ "$TTBUILDI" == 1 ] || [ "$TTBUILDI" == 6 ] || [ "$TTBUILDI" == 8 ];then
partition='erofs'
elif [ "$TTBUILDI" == 2 ] || [ "$TTBUILDI" == 3 ] || [ "$TTBUILDI" == 7 ];then
partition='ext'
elif [ "$TTBUILDI" == 4 ] || [ "$TTBUILDI" == 5 ];then
partition='f2fs'
else
partition="$info_type"
fi

if [ "$NENEROFS" == "lz4" ];then
[ "$TTBUILDI" == 6 ] && zlsize=',0' || zlsize=''
elif [ "$NENEROFS" == "lz4hc" ];then
[ "$LVLNEN" -gt 12 ] && zlsize=",12" || zlsize=",$LVLNEN"
elif [ "$NENEROFS" == "deflate" ] || [ "$NENEROFS" == "lzma" ];then
[ "$LVLNEN" -gt 9 ] && zlsize=",9" || zlsize=",$LVLNEN"
else
[ "$LVLNEN" -gt 22 ] && zlsize=",22" || zlsize=",$LVLNEN"
fi

[ -e "$OUTPUT/out" ] || mkdir -p "$OUTPUT/out"
echo -e "$replag_text_2: ${INPUT##*/} ($partition) ➠ (raw)...\n"

process_count(){
PIDK=$!
num1="$1"; num2="$2";
while kill -0 $PIDK 2>/dev/null; do
if [ -f "$num2" ];then
    num3=$(stat -c %s "$num2")
    if [ "${num3:-0}" != 0 ];then
    [ "${num3:-0}" == "${num4:-1}" ] || progress "$((num3 * 100 / num1))/100"
    num4="$num3"
    fi
fi
sleep 1
done
progress -1/0
}

process_erofss(){
PIDK=$!
while kill -0 $PIDK 2>/dev/null; do
if [ -f "$1" ];then
    num1="$(grep "^loaded .*. fs_config entries" $1 | awk '{print $2}')"
    num2="$(echo "$(grep -c 'Processing' $1) + 1" | bc)"
    if [ "${num2:-0}" != 0 ];then
    [ "${num2:-0}" == "${num4:-1}" ] || progress "$((num2 * 100 / num1))/100"
    num4="$num2"
    fi
fi
sleep 1
done
progress -1/0
}

process_mksquashfs(){
PIDK=$!
while kill -0 $PIDK 2>/dev/null; do
if [ -f $1 ];then
number_kk="$(sed 's/[\r\t]/\n/g' $1 | sed -n 's/.* \([0-9]\+\)%$/\1/p' | tail -n 1)"
  if [ "${number_kk:-0}" != 0 ];then
  [ "${number_kk:-0}" == "${save_num:-1}" ] || progress $number_kk/100
  save_num="$number_kk"
  fi
fi
sleep 1
done
progress -1/0
}

process_zstd(){
PIDK=$!
while kill -0 $PIDK 2>/dev/null; do
if [ -f "$1" ];then
num2="$(tr '\r' '\n' < "$1" | awk '/Read:/{r=$2*($3=="GiB"?1024:1); t=$5*($6=="GiB"?1024:1)} END{print (t>0?int(r/t*100):0)}')"
[ $num2 == 0 ] && num2="$(tr '\r' '\n' < "$1" | awk '/^Read/{r=$3; t=$5} END{print (t>0?int(r/t*100):0)}')"
    if [ "${num2:-0}" != 0 ];then
    [ "${num2:-0}" == "${num4:-1}" ] || progress "$num2/100"
    num4="$num2"
    fi
fi
sleep 1
done
progress -1/0
}

if [ "$partition" == "erofs" ];then
    [ "$DISATFS" == 0 ] || patch "$INPUT" "$fs_config" "$file_contexts" >$TMP/patch_fs.log
    if [ "$TTBUILDI" == 6 ];then
    imgkit_scuti pack --type erofs -s "$INPUT" -o "$saved" --compress $NENEROFS --compress-level ${zlsize/,/} --file-contexts "$file_contexts" --fs-config "$fs_config" -m "/${INPUT##*/}" &>$TMP/imgkit_repack.log || killtree "Error build process imgkit_scuti:\n\n$(cat $TMP/imgkit_repack.log)" "$saved"
    elif [ "$TTBUILDI" == 8 ];then
    $TERMUX/lib/theft/mkfs.erofs -T $time_build -z${NENEROFS}${zlsize} --mount-point="/${INPUT##*/}" --fs-config-file="$fs_config" --file-contexts="$file_contexts" "$saved" "$INPUT" &>$TMP/mkfs_erofs.log || killtree "Error build process mkfs.erofs:\n\n$(cat $TMP/mkfs_erofs.log)" "$saved" &
    process_erofss $TMP/mkfs_erofs.log
    else
    mkfs.erofs -T $time_build -z${NENEROFS}${zlsize} --mount-point="/${INPUT##*/}" --fs-config-file="$fs_config" --file-contexts="$file_contexts" "$saved" "$INPUT" &>$TMP/mkfs_erofs.log || killtree "Error build process mkfs.erofs:\n\n$(cat $TMP/mkfs_erofs.log)" "$saved" &
    process_erofss $TMP/mkfs_erofs.log
    fi
elif [ "$partition" = "boot" ] || [ "$partition" = "vendor_boot" ]; then
    # xây dựng cpio
    for vch in $(cat "$INPUT/cache/cpio" 2>/dev/null); do
    cd "$INPUT/${vch%.*}"
    find | sed 1d | cpio -H newc -R 0:0 -o -F "$INPUT/$vch"
    done
    # xây dựng dtb
    cd "$INPUT"
    for redts in $(ls -1d dts_*.+([0-9]) 2>/dev/null | sort -n -t . -k 2); do
        nrep="${redts/dts_/}"
        if [ "$(checksum $redts)" == "$(cat cache/md5_$nrep)" ];then
        cp -f cache/${nrep} ${nrep}
        else
        echo "Build DTB: $redts"
        dtc -q -I dts -O dtb -@ -o ${nrep} $redts
        [ "$?" != 0 ] && killtree "Error: Build DTB"
        fi
    done
    for bdts in $(ls -1d cache/type_* 2>/dev/null); do
        nedts="${bdts/cache\/type_/}"
        tydbs="$(cat $bdts)"
        if [ "$tydbs" == 'dtb' ] || [ "$tydbs" == 'dtbo' ];then
        [ "$tydbs" == 'dtb' ] && merge_dtb.py $nedts $(ls -1d $nedts.* | sort -n -t . -k 2) >/dev/null
        [ "$tydbs" == 'dtbo' ] && dtbo create $nedts $(ls -1d $nedts.* | sort -n -t . -k 2) >/dev/null
        fi
        rm -f $nedts.*
    done
    # xây dựng boot
    magiskboot repack "${INPUT##*/}.img" "$saved" 2>&1
    echo
elif [ "$partition" = "vbmeta_system" ] || [ "$partition" = "vbmeta" ]; then
    cd $INPUT
    cp -rf "${INPUT##*/}.img" "$saved"
elif [ "$partition" = "logo" ];then
    logo_dumper.py --out "$INPUT/new-logo.img" --bmpdir "$INPUT" "$INPUT/logo.img" repack
    mv -f "$INPUT/new-logo.img" "$saved"
    echo
elif [ "$partition" = "dtbo" ];then
    cd "$INPUT"
    for dtbo in $(ls -1d dts.* | sort -n -t . -k 2); do
        if [ "$(checksum $dtbo)" == "$(cat cache/md5_$dtbo 2>/dev/null)" ];then
        echo "Copy raw: dtb.${dtbo##*.}"
        cp -f cache/dtb.${dtbo##*.} dtb.${dtbo##*.}
        else
        echo "Build dtb: $dtbo"
        dtc -q -I dts -O dtb -@ -o dtb.${dtbo##*.} $dtbo
        [ "$?" != 0 ] && killtree "Error: Build dtb"
        fi
    done
    dtbo create dtbo.img $(ls -1d dtb.* | sort -n -t . -k 2) >/dev/null
    rm -fr dtb.*
    cp -f dtbo.img "$saved"
    echo
elif [ "$partition" == "squashfs" ];then
    [ "$ROT" == 0 ] && killtree "Error build: squashfs, $root_warning_text"
    loai_nen="$(grep '^Compression' "$fs_options" | awk '{print $2}')"
    [ -z "$loai_nen" ] && loai_nen='xz'
    loai_block="$(grep '^Block size' "$fs_options" | awk '{print $3}')"
    [ -z "$loai_block" ] && loai_block=131072
    loai_attrs="$(grep -cm1 '^Xattrs are compressed' "$fs_options")"
    [ -z "$loai_attrs" ] || loai_attrs='-xattrs'
    mksquashfs "$INPUT" "${saved%.*}.squashfs" -comp "$loai_nen" -b $loai_block -Xdict-size 100% $loai_attrs -noappend &>$TMP/mksquashfs.log || killtree "\nError build process mksquashfs:\n\n$(cat $TMP/mksquashfs.log)" "${saved%.*}.squashfs" & process_mksquashfs "$TMP/mksquashfs.log"
    echo
elif [ "$partition" == "f2fs" ];then
    [ "$DISATFS" == 0 ] || patch "$INPUT" "$fs_config" "$file_contexts" >$TMP/patch_fs.log
    if [ -f "$info_size" ] && [ "$info_type" == "f2fs" ];then
    size_real=$(cat $info_size 2>/dev/null);
    size_real="$(echo "$SAINEN * 1024 * 1024 + $size_real" | bc)"
    else
    size_orig="$(du -bs "$INPUT" | awk '{ print $1 }')"
    size_real="$(echo "($SAINEN + 6) * 1024 * 1024 + $size_orig" | bc)"
    fi
    truncate -s $size_real "$saved"
    if [ -f "$INPUT/system/build.prop" ];then
    mount_dir="/"
    cp -rf "$fs_config" "${fs_config}_s"
    cp -rf "$file_contexts" "${file_contexts}_s"
    fs_config="${fs_config}_s"
    file_contexts="${file_contexts}_s"
    sed -i -e "/^${INPUT##*/} 0/d" -e "s|^${INPUT##*/}/|/|" "$fs_config"
    sed -i -e "/^\/${INPUT##*/} u/d" -e "/^\/${INPUT##*/}\/ u/d" -e "s|^/${INPUT##*/}||" "$file_contexts"
    else
    mount_dir="/${INPUT##*/}"
    fi
    if [ "$TTBUILDI" == 0 ];then
    [ "$(cat "$fs_options" 2>/dev/null | grep 'superblock features' | grep -cm1 ro)" == 1 ] && TTBUILDI=4 || TTBUILDI=5
    fi
    if [ "$TTBUILDI" == 5 ];then
    make_f2fs -g android -O compression -r -w 4096 -l "${INPUT##*/}" -f "$saved" $size_real &>$TMP/make_f2fs.log || killtree "Error build make_f2fs, log: $TMP/make_f2fs.log" "$saved"
    sload_f2fs -t "$mount_dir" -C "$fs_config" -s "$file_contexts" -T $time_build -f "$INPUT" -c "$saved" 2>&1 | tee $TMP/sload_f2fs.log | sed -e "/Free segments:/d" -e "/Not enough space/d"
    else
    make_f2fs -t 0 -g android -O ro -r -w 4096 -l "${INPUT##*/}" -f "$saved" $size_real &>$TMP/make_f2fs.log || killtree "Error build make_f2fs, log: $TMP/make_f2fs.log" "$saved"
    sload_f2fs -t "$mount_dir" -C "$fs_config" -s "$file_contexts" -T $time_build -f "$INPUT" "$saved" 2>&1 | tee $TMP/sload_f2fs.log | sed -e "/Free segments:/d" -e "/Not enough space/d"
    fi
    [ "$(grep -cm1 'Done:' $TMP/sload_f2fs.log)" == 0 ] && killtree "Error build sload_f2fs, Suggestion: Increase free MB, log: $TMP/sload_f2fs.log" "$saved";
    [ -f "$INPUT/system/build.prop" ] && rm -f "$file_contexts" "$fs_config"
    echo
elif [ "$partition" == "ext" ];then
    [ "$DISATFS" == 0 ] || patch "$INPUT" "$fs_config" "$file_contexts" >$TMP/patch_fs.log
    size_real=$(cat $info_size 2>/dev/null);
    size_orig="$(du -sb "$INPUT" | awk '{ print $1 }')"
    if test "$size_orig" -le "52428800"; then
    size_orig=209715200
    else
    size_orig="$(echo "$size_orig * 1.1" | bc | cut -d. -f1)"
    fi
    if [ "$SAINEN" == 0 ] && [ "$info_type" == "ext" ] && [ -f "$info_size" ];then
        if [ "$TTBUILDI" == 3 ];then
        size="$(echo "$size_real / 4096" | bc)";
        mke2fs -O ^has_journal -t ext4 -m 0 -b 4096 -I 256 -L "${INPUT##*/}" -M "/${INPUT##*/}" "$saved" $size 2>&1
        e2fsdroid -e -T $time_build -C "$fs_config" -S "$file_contexts" -f "$INPUT" -a "/${INPUT##*/}" "$saved" || killtree "Error build process e2fsdroid" "$saved"
        elif [ "$TTBUILDI" == 7 ];then
        imgkit_scuti pack --type ext4 -s "$INPUT" -o "$saved" -z $size_real --file-contexts "$file_contexts" --fs-config "$fs_config" -m "/${INPUT##*/}" --label "${INPUT##*/}" &>$TMP/imgkit_repack.log || killtree "Error build process imgkit_scuti:\n\n$(cat $TMP/imgkit_repack.log)" "$saved"
        else
        make_ext4fs -J -T $time_build -L "${INPUT##*/}" -S "$file_contexts" -C "$fs_config" -l $size_real -a "/${INPUT##*/}" "$saved" "$INPUT" || killtree "Error build process make_ext4fs" "$saved" &
        process_count $size_real "$saved"
        echo
        fi
    else
        if [ "$TTBUILDI" == 3 ];then
        size="$(echo "$size_orig / 4096" | bc)";
        mke2fs -O ^has_journal -t ext4 -m 0 -b 4096 -I 256 -L "${INPUT##*/}" -M "/${INPUT##*/}" "$saved" $size 2>&1
        e2fsdroid -e -T $time_build -C "$fs_config" -S "$file_contexts" -f "$INPUT" -a "/${INPUT##*/}" "$saved" || killtree "Error build process e2fsdroid" "$saved"
        elif [ "$TTBUILDI" == 7 ];then
        imgkit_scuti pack --type ext4 -s "$INPUT" -o "$saved" -z $size_orig --file-contexts "$file_contexts" --fs-config "$fs_config" -m "/${INPUT##*/}" --label "${INPUT##*/}" &>$TMP/imgkit_repack.log || killtree "Error build process imgkit_scuti:\n\n$(cat $TMP/imgkit_repack.log)" "$saved"
        else
        make_ext4fs -J -T $time_build -L "${INPUT##*/}" -S "$file_contexts" -C "$fs_config" -l $size_orig -a "/${INPUT##*/}" "$saved" "$INPUT" || killtree "Error build process make_ext4fs" "$saved" &
        process_count $size_orig "$saved"
        echo
        fi
        resize2fs -M "$saved" 2>&1
        if [[ "$SAINEN" != 0 ]];then
        kichthuoc="$(resize2fs -P "$saved" 2>/dev/null | grep -o '[0-9]*')"
        resize2fs -f "$saved" $(echo "$SAINEN * 1024 / 4 + $kichthuoc" | bc) 2>&1
        fi
    fi
fi

if [[ -f $PTSD/dynamic_partitions_op_list ]] && [[ "$partition" =~ ^(ext|f2fs|erofs)$ ]];then
    cp -f $PTSD/dynamic_partitions_op_list $OUTPUT/out/dynamic_partitions_op_list
    if [ -f "$saved" ];then
    img_size=$(stat -c %s "$saved")
    sed -i "s/resize ${INPUT##*/} [^*]*/resize ${INPUT##*/} $img_size/" $OUTPUT/out/dynamic_partitions_op_list
    fi
fi

if [[ "$partition" =~ ^(erofs|f2fs|ext)$ ]];then
    [ "$img_size" ] && text_sizes="$img_size" || text_sizes=$(stat -c %s "$saved")
    echo "$sizes_text: ${saved##*/} $(coverbyte $text_sizes) ($text_sizes)"
    echo
    if [ "$CONVER" != "raw" ];then
    echo -e "$unpack_text_0 ${INPUT##*/} (raw) ➠ ($CONVER)..."
    echo
    fi
    if [ "$CONVER" == 'zstd' ] || [ "$CONVER" == 'gz' ] || [ "$CONVER" == 'xz' ] || [ "$CONVER" == 'lz4' ] || [ "$CONVER" == 'lzma' ];then
    zstd --progress -f -$lvnen --format=$CONVER --compress "$saved" -o "${out_saved%.*}.img.$CONVER" &>"$TMP/repzstd.log" || killtree "Cover zstd error" & process_zstd $TMP/repzstd.log
    elif [ "$CONVER" == 'dat' ] || [ "$CONVER" == 'br' ];then
    img2simg "$saved" >$TMP/img2simg.log
    img2sdat "$saved" -o "$OUTPUT/out" -v 4 -p "${INPUT##*/}" &>$TMP/img2sdat.log
    [ -f "$OUTPUT/out/${INPUT##*/}.new.dat" ] || killtree "Error creating file ${INPUT##*/}.new.dat failed !!!"
        if [ "$CONVER" == 'br' ];then
        LEVEL="$(echo "$lvnen / 2" | bc)"
        brotli -fq "$LEVEL" "$OUTPUT/out/${INPUT##*/}.new.dat" -o "$OUTPUT/out/${INPUT##*/}.new.dat.br" >$TMP/brotli.log && rm -f "$OUTPUT/out/${INPUT##*/}.new.dat"
        fi
    elif [ "$CONVER" == 'sparse' ];then
    img2simg "$saved" "$out_saved" >/dev/null
    fi
    [ "$CONVER" != "raw" ] && rm -f "$saved"
fi

if [ "$CDELIMG" == 1 ];then
rm -fr "$INPUT" "$file_contexts" "$fs_config" "$info" "$fs_options" "$info_size"
fi
